{
  "name": "podforge",
  "version": "0.1.5",
  "description": "Podcast CLI utilities for downloading and transcribing podcast episodes.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dairui1/podforge.git"
  },
  "homepage": "https://github.com/dairui1/podforge#readme",
  "bugs": {
    "url": "https://github.com/dairui1/podforge/issues"
  },
  "keywords": [
    "podcast",
    "cli",
    "transcription",
    "elevenlabs",
    "xiaoyuzhou",
    "subtitles"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "podforge": "dist/cli.js"
  },
  "files": [
    "dist",
    "scripts",
    "skills"
  ],
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run test",
    "audit": "pnpm audit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:live": "vitest run test/live*.test.ts",
    "prepublishOnly": "pnpm run check && pnpm run build"
  },
  "dependencies": {
    "@ai-sdk/assemblyai": "^2.0.24",
    "@ai-sdk/deepgram": "^2.0.24",
    "@ai-sdk/elevenlabs": "2.0.24",
    "@ai-sdk/gladia": "^2.0.24",
    "@ai-sdk/groq": "^3.0.29",
    "@ai-sdk/openai": "^3.0.41",
    "@ai-sdk/provider-utils": "4.0.19",
    "@ai-sdk/revai": "^2.0.24",
    "ai": "6.0.116",
    "commander": "14.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@types/node": "25.5.0",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  }
}
